# 可选：覆盖后端地址（默认走 Vite proxy，开发无需设置）
# VITE_API_BASE=http://127.0.0.1:8000
# VITE_WS_BASE=ws://127.0.0.1:8000

# 可选：Live2D Cubism 4 模型入口，指向 .model3.json
# VITE_LIVE2D_MODEL_URL=/live2d/Hiyori/Hiyori.model3.json
# 可选：Cubism Core 脚本地址；生产环境建议放到 public/ 后改成本地路径
# VITE_LIVE2D_CUBISM_CORE_URL=/live2d/live2dcubismcore.min.js
# 可选：Live2D 舞台适配微调
# VITE_LIVE2D_MODEL_SCALE=1
# VITE_LIVE2D_MODEL_OFFSET_X=0
# VITE_LIVE2D_MODEL_OFFSET_Y=0
